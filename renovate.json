{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "kubernetes",
    "argocd"
  ],
  "includePaths": [
    "kubernetes/**/*"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/^kubernetes/.+\\.ya?ml$/"
    ]
  },
  "argocd": {
    "managerFilePatterns": [
      "/^kubernetes/argocd/apps/.+\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "matchManagers": ["kubernetes", "argocd"],
      "groupName": "kubernetes updates"
    }
  ]
}
