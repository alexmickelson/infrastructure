{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "kubernetes",
    "argocd"
  ],
  "includePaths": [
    "kubernetes/**/*"
  ],
  "packageRules": [
    {
      "matchManagers": ["kubernetes", "argocd"],
      "groupName": "kubernetes updates"
    }
  ]
}
