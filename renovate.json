{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "minimumReleaseAge": "2 days",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "kubernetes",
    "argocd"
  ],
  "includePaths": [
    "kubernetes/**/*"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/^kubernetes/.+\\.ya?ml$/"
    ]
  },
  "argocd": {
    "managerFilePatterns": [
      "/^kubernetes/argocd/apps/.+\\.ya?ml$/"
    ]
  }
}
