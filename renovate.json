{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "minimumReleaseAge": "2 days",
  "branchPrefix": "renovate-",
  "automerge": true,
  "internalChecksAsSuccess": true,
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "kubernetes",
    "argocd"
  ],
  "includePaths": [
    "kubernetes/**/*"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/^kubernetes/.+\\.ya?ml$/"
    ],
    "digest": {
      "enable": true
    }
  },
  "argocd": {
    "managerFilePatterns": [
      "/^kubernetes/argocd/apps/.+\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "description": "Require manual review for PostgreSQL major upgrades",
      "matchPackageNames": ["postgres"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
